{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../web-ui/src/*"],
      "@web-ui/*": ["../web-ui/src/*"]
    },
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "electron.vite.config.ts",
    "../web-ui/env.d.ts"
  ],
  "exclude": ["node_modules", "out", "release"]
}
