{
  "name": "virtual-tcu-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev:dashboard": "pnpm --filter virtual-tcu-web-ui dev",
    "dev:electron": "pnpm --filter virtual-tcu dev",
    "build:dashboard": "pnpm --filter virtual-tcu-web-ui build",
    "build:electron": "pnpm --filter virtual-tcu build",
    "build": "pnpm build:dashboard && pnpm build:electron",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.11.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~5.9.3",
    "vue-tsc": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "@electron-toolkit/utils>electron": "^33.2.1"
    }
  }
}
